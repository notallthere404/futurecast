# Every env var the server, compose stack, and config.yaml reference.
# Copy to .env and fill in the values that apply to your deployment.
# Empty values are inherited from defaults where applicable.

# ───────────── General ─────────────
# Path inside the server container to the YAML config. Compose mounts
# config.yaml here; override for non-compose deploys.
CONFIG_FILE=

# ───────────── Server ─────────────
# Listen port the server binds to. Compose publishes this on the host.
PORT=
# Optional file path for the slog text handler. Empty = stdout only.
LOG_FILE=
# debug | info | warn | error. Default is info.
LOG_LEVEL=

# ───────────── Database ─────────────
# Standard libpq vars consumed by the postgres image entrypoint.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
# Full DSN the server reads. Wins over server.ext_db in config.yaml
# when both are set.
DATABASE_URL=
# Host:container mapping passed to compose, e.g. 7433:5432
DATABASE_PORT=

# ───────────── Self-hosted inference ─────────────
# Port the Python container exposes inside the docker network.
INFERENCE_PORT=
# Base URL the server uses to reach the Python service. Used only when
# inference.type is zeroshot or llm; ignored for api mode.
INFERENCE_URL=
# Model id loaded at Python startup. Overridden at runtime by POST
# /load from the Go side; useful for cold-start defaults.
INFERENCE_MODEL=
# zeroshot | llm. Picks which backend the Python service constructs at
# boot. Defaults to zeroshot when unset.
INFERENCE_TYPE=

# ───────────── Remote inference (type=api) ─────────────
# Referenced from config.yaml as ${OPENROUTER_API_KEY} (or any name
# you pick). The server's env-expand DecodeHook resolves it at config
# load. Compatible providers: OpenRouter, OpenAI, Together, Groq,
# vLLM, Anthropic's OpenAI-compat endpoint.
OPENROUTER_API_KEY=

# ───────────── Webhook source auth ─────────────
# Referenced from config.yaml under inference webhook sources as
# ${WEBHOOK_SECRET}. HMAC-SHA256 of the request body must match the
# header named in the source's auth.header.
WEBHOOK_SECRET=

# ───────────── Outbound HTTP source auth ─────────────
# Per-source bearer / api-key tokens. Add as many as your config
# references; the env-expand hook picks them up by name.
HTTP_FEED_TOKEN=
